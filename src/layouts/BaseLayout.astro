---
import "../styles/global.css";
import "../styles/typography.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site.config";
import { siteConfig } from "../config/site.config";

type Props = {
  title: string;
  description: string;
};

const blogSearchPosts = (await getCollection("blog", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "blog",
}));

const researchSearchPosts = (await getCollection("research", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "research",
}));

const allSearchPosts = [...blogSearchPosts, ...researchSearchPosts];
allSearchPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const searchIndex = allSearchPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  date: post.data.date.toISOString(),
  href:
    post.collection === "blog"
      ? `/blog/${post.id.replace(/\.mdx?$/, "")}/`
      : `/research-notes/${post.id.replace(/\.mdx?$/, "")}/`,
}));

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-FHHNFNDEPZ"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());

  gtag('config', 'G-FHHNFNDEPZ');
</script>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:image" content="/images/og-default.png" />

    <link rel="icon" href={siteConfig.external.favicon} />
    <link rel="canonical" href={Astro.url} />

    {siteConfig.external.preconnect.map((url) => (
      <link rel="preconnect" href={url} crossorigin={url.includes('fonts.gstatic.com') ? true : undefined} />
    ))}

    {siteConfig.external.fonts.map((href) => (
      <link href={href} rel="stylesheet" />
    ))}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="reading-progress" id="reading-progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-label="Reading progress" aria-hidden="true"></div>
    <div class="page-bg">
      <div class="card-shell">
        <div id="scroll-sentinel" style="position:absolute;top:0;height:1px;width:1px;pointer-events:none;" aria-hidden="true"></div>
        <Header />
        <div class="search-results-panel" id="search-results-panel" hidden>
          <div class="search-results-inner">
            <ul class="search-results-list" id="search-results-list" role="listbox"></ul>
          </div>
        </div>
        <main id="main">
          <slot />
        </main>
        <Footer />
      </div>
    </div>
    <button class="back-to-top" id="back-to-top" type="button" aria-label="Back to top">
      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m18 15-6-6-6 6" />
      </svg>
    </button>

    <script set:html={`window.__SEARCH_POSTS__ = ${JSON.stringify(searchIndex)};`}></script>
    <script src="/scripts/ui.js" defer></script>
  </body>
</html>

<style>
  .skip-link {
    position: absolute;
    left: 1rem;
    top: 1rem;
    z-index: 100;
    transform: translateY(-200%);
    padding: 0.75rem 1rem;
    background: var(--color-text);
    color: white;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }

  .skip-link:focus {
    transform: translateY(0);
  }
</style>
