---
import BaseLayout from "./BaseLayout.astro";
import ArticleTOC from "../components/ArticleTOC.astro";
import { siteConfig } from "../config/site.config";

type Props = {
  title: string;
  description: string;
  category: string;
  date: Date;
  tags?: string[];
  headings?: { depth: number; slug: string; text: string }[];
  image?: string;
  updated?: Date;
  readingTime: string;
};

const { title, description, category, date, tags = [], headings = [], image, updated, readingTime } = Astro.props;
const formattedDate = new Intl.DateTimeFormat("en", {
  month: "long",
  day: "numeric",
  year: "numeric",
}).format(date);

const pageUrl = `${Astro.site}${Astro.url.pathname}`;
const imageUrl = image ? (image.startsWith("http") ? image : `${Astro.site}${image}`) : `${Astro.site}/images/og-default.png`;

const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  dateModified: (updated ?? date).toISOString(),
  author: {
    "@type": "Person",
    name: siteConfig.author.name,
    jobTitle: siteConfig.author.role,
    description: siteConfig.author.bio,
    sameAs: [siteConfig.author.github, siteConfig.author.linkedin, siteConfig.author.huggingFace].filter(Boolean),
  },
  publisher: {
    "@type": "Organization",
    name: siteConfig.publisher.name,
    logo: {
      "@type": "ImageObject",
      url: `${siteConfig.siteUrl}${siteConfig.publisher.logo}`,
    },
  },
  image: [imageUrl],
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": pageUrl,
  },
};
---

<BaseLayout
  title={`${title} — GinkgoQ`}
  description={description}
  pageImage={imageUrl}
  pageType="article"
  datePublished={date.toISOString()}
  dateModified={(updated ?? date).toISOString()}
>
  <article class="article container">
    <div class="article-main">
      <a class="back-link" href={Astro.url.pathname.startsWith("/blog/") ? "/blog/" : "/research-notes/"}>
        <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 8H3M8 3 3 8l5 5" /></svg>
        {Astro.url.pathname.startsWith("/blog/") ? "Blog" : "Research Notes"}
      </a>

      <header class="article-header">
        <span class="eyebrow">{category}</span>
        <h1>{title}</h1>
        <p class="dek">{description}</p>

        <div class="article-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span>{readingTime}</span>
          {tags.slice(0, 3).map((tag) => <span class="tag-pill">{tag}</span>)}
        </div>
      </header>

      <div class="prose">
        <slot />
      </div>

      <div class="article-end" aria-hidden="true"><span>· · ·</span></div>

      <div class="article-actions">
        <button class="share-btn" id="share-btn" type="button" aria-label="Share this article">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3" /><circle cx="6" cy="12" r="3" /><circle cx="18" cy="19" r="3" /><line x1="8.59" y1="13.51" x2="15.42" y2="17.49" /><line x1="15.41" y1="6.51" x2="8.59" y2="10.49" /></svg>
          Share this note
        </button>
        <a class="back-link" href={Astro.url.pathname.startsWith("/blog/") ? "/blog/" : "/research-notes/"}>
          <svg viewBox="0 0 16 16" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M13 8H3M8 3 3 8l5 5" /></svg>
          Back to {Astro.url.pathname.startsWith("/blog/") ? "Blog" : "Research Notes"}
        </a>
      </div>

      <aside class="author-card" aria-label="About the author">
        <strong>{siteConfig.author.name}</strong>
        <p>{siteConfig.author.bio}</p>
      </aside>
    </div>

    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />

    <ArticleTOC headings={headings} />
  </article>
</BaseLayout>

<style>
  .article {
    display: grid;
    grid-template-columns: minmax(0, 760px) 260px;
    gap: 6rem;
    padding: 70px 0 96px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 4rem;
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: gap 180ms var(--ease);
  }

  .back-link:hover {
    gap: 0.62rem;
  }

  .eyebrow {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .article-header h1 {
    margin: 0;
    font-size: clamp(2.25rem, 4vw, 4.2rem);
    line-height: 1.02;
    letter-spacing: -0.06em;
  }

  .dek {
    max-width: 680px;
    margin: 1.3rem 0 1.4rem;
    color: var(--color-muted);
    font-size: 1.22rem;
    line-height: 1.55;
  }

  .article-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1.1rem;
    color: var(--color-muted);
    font-size: 0.92rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--color-line);
  }

  .prose {
    padding-top: 2.5rem;
  }

  .article-end {
    margin: 2.5rem 0 0;
    color: var(--color-subtle);
    text-align: center;
    letter-spacing: 0.5em;
  }

  .article-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .article-actions .back-link {
    margin-bottom: 0;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    color: var(--color-muted);
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    font-size: 0.84rem;
    font-weight: 600;
    cursor: pointer;
    transition: color 140ms, border-color 140ms, background-color 140ms;
  }

  .share-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent-soft);
    background: var(--color-accent-soft);
  }

  @media (max-width: 1040px) {
    .article {
      grid-template-columns: 1fr;
    }
  }
</style>
