---
import BaseLayout from "../layouts/BaseLayout.astro";
import SignalGridDots from "../components/SignalGridDots.astro";
import BrandText from "../components/BrandText.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site.config";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "blog",
}));

const researchPosts = (await getCollection("research", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "research",
}));

const allPosts = [...blogPosts, ...researchPosts];
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestPosts = allPosts.slice(0, 3);
const processSteps = [
  {
    title: "Sense",
    description: "Capture the right signals.",
    icon: "/images/home/sense.svg",
  },
  {
    title: "Structure",
    description: "Organize chaos into context.",
    icon: "/images/home/structure.svg",
  },
  {
    title: "Reason",
    description: "Apply models that understand.",
    icon: "/images/home/reason.svg",
  },
  {
    title: "Act",
    description: "Deliver intelligence that matters.",
    icon: "/images/home/act.svg",
  },
];

const getHref = (post) =>
  post.collection === "blog"
    ? `/blog/${post.id.replace(/\.mdx?$/, "")}/`
    : `/research-notes/${post.id.replace(/\.mdx?$/, "")}/`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);

const getReadTime = (post) => {
  const rawBody =
    typeof post.body === "string"
      ? post.body
      : typeof post.body?.raw === "string"
      ? post.body.raw
      : "";
  const words = rawBody.trim().split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 220))} min`;
};
---

<BaseLayout title={siteConfig.pages.home.title} description={siteConfig.pages.home.description}>
  <section class="home-hero" aria-labelledby="hero-heading">
    <div class="home-hero-visual" aria-hidden="true">
      <img class="signal-art signal-art-light" src="/images/home/light.png" alt="" loading="eager" decoding="async" />
      <img class="signal-art signal-art-dark" src="/images/home/dark.png" alt="" loading="eager" decoding="async" />
      <div class="alive-grid">
        <SignalGridDots />
      </div>
    </div>

    <div class="home-hero-inner container">
      <div class="hero-copy">
        <p class="wordmark">
          <BrandText text={siteConfig.brand.label} />
        </p>
        <span class="hero-rule" aria-hidden="true"></span>
        <h1 id="hero-heading">Turning complex signals into real-world <span>intelligence.</span></h1>

        <div class="process-steps" aria-label="GinkgoQ process">
          {processSteps.map((step) => (
            <article class="process-step">
              <span class="step-icon" style={`--icon-url: url("${step.icon}")`} aria-hidden="true"></span>
              <h2>{step.title}</h2>
              <p>{step.description}</p>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="home-sections container" aria-label="GinkgoQ sections">
    {siteConfig.pages.home.sections.map((section) => (
      <a class="section-card" href={section.href}>
        <span class="sc-num" aria-hidden="true">{section.number}</span>
        <h3>{section.title}</h3>
        <p>{section.description}</p>
        <span class="sc-more">{section.actionText}</span>
      </a>
    ))}
  </section>

  <section class="home-latest container" aria-labelledby="latest-heading">
    <div class="sec-row">
      <h2 id="latest-heading">{siteConfig.pages.home.latestHeading}</h2>
      <a href={siteConfig.routes.blog}>{siteConfig.pages.home.latestViewAllText}</a>
    </div>

    <div id="home-posts" role="list">
      {latestPosts.map((post) => (
        <a class="home-post-row" href={getHref(post)} role="listitem">
          <div class="home-post-row-inner">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="cat">{post.data.category}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p class="desc">{post.data.description}</p>
          </div>
          <span class="home-post-read">{getReadTime(post)} read</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    min-height: clamp(620px, 66vw, 790px);
    overflow: clip;
    isolation: isolate;
    background: #fdfdfb;
    transition: background 240ms var(--ease);
  }

  :global([data-theme="dark"]) .home-hero {
    background: #000;
  }

  .home-hero::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(circle at 18% 32%, rgb(121 134 60 / 0.16), transparent 25rem),
      linear-gradient(90deg, rgb(121 134 60 / 0.07), transparent 43%);
    mix-blend-mode: multiply;
  }

  :global([data-theme="dark"]) .home-hero::before {
    background:
      radial-gradient(circle at 18% 32%, rgb(121 134 60 / 0.34), transparent 25rem),
      linear-gradient(90deg, rgb(121 134 60 / 0.14), transparent 43%);
    mix-blend-mode: screen;
  }

  .home-hero-visual {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    user-select: none;
  }

  .signal-art {
    position: absolute;
    z-index: 0;
    top: 50%;
    right: max(10px, 0.8vw);
    width: min(74vw, 990px);
    height: auto;
    max-width: none;
    transform: translateY(-48%);
    object-fit: contain;
    object-position: center;
    opacity: 1;
  }

  .signal-art-dark {
    display: none;
  }

  :global([data-theme="dark"]) .signal-art-light {
    display: none;
  }

  :global([data-theme="dark"]) .signal-art-dark {
    display: block;
    opacity: 1;
    mix-blend-mode: normal;
  }

  .alive-grid {
    position: absolute;
    z-index: 2;
    left: max(42%, 520px);
    top: 50%;
    width: min(34vw, 470px);
    opacity: 0.25;
    transform: translate(-50%, -50%) scaleX(1.08);
    mix-blend-mode: multiply;
    filter: saturate(0.86);
  }

  :global([data-theme="dark"]) .alive-grid {
    opacity: 0.18;
    mix-blend-mode: screen;
    filter: saturate(0.95) brightness(1.05);
  }

  .home-hero-inner {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    min-height: inherit;
    padding-top: 36px;
    padding-bottom: 54px;
  }

  .hero-copy {
    width: min(44vw, 540px);
    padding-top: clamp(1rem, 5vw, 5rem);
  }

  .wordmark {
    display: flex;
    gap: clamp(0.72rem, 1.35vw, 1.25rem);
    align-items: center;
    margin: 0 0 2rem;
    color: var(--color-text);
    font-size: clamp(2.15rem, 4vw, 3.15rem);
    font-weight: 360;
    line-height: 1;
    letter-spacing: 0;
  }

  .wordmark :global(.brand-word) {
    display: inline-flex;
    gap: clamp(0.72rem, 1.35vw, 1.25rem);
    align-items: center;
  }

  .wordmark :global(.brand-q) {
    color: var(--color-theme-green);
    font-weight: 620;
  }

  .hero-rule {
    display: block;
    width: 32px;
    height: 3px;
    margin-bottom: 2rem;
    background: var(--color-accent);
    border-radius: 999px;
  }

  .hero-copy h1 {
    max-width: 480px;
    margin: 0;
    color: var(--color-text);
    font-size: clamp(2rem, 3vw, 3rem);
    font-weight: 390;
    line-height: 1.36;
    letter-spacing: 0;
    text-wrap: balance;
  }

  .hero-copy h1 span {
    color: var(--color-accent);
    font-weight: 680;
  }

  .process-steps {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    width: min(100%, 560px);
    margin-top: clamp(2.8rem, 6vw, 4.4rem);
  }

  .process-step {
    min-width: 0;
    padding: 0 1.55rem;
    border-left: 1px solid color-mix(in srgb, var(--color-accent) 32%, transparent);
  }

  .process-step:first-child {
    padding-left: 0;
    border-left: 0;
  }

  .step-icon {
    display: block;
    width: 42px;
    height: 34px;
    margin-bottom: 1rem;
    background: var(--color-accent);
    -webkit-mask: var(--icon-url) center / contain no-repeat;
    mask: var(--icon-url) center / contain no-repeat;
  }

  .process-step h2 {
    margin: 0 0 0.55rem;
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.24em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .process-step p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.83rem;
    line-height: 1.55;
  }

  .home-sections {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-top: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .section-card {
    display: block;
    color: inherit;
    text-decoration: none;
    padding: 2.2rem 1.8rem;
    border-right: 1px solid var(--color-line);
    position: relative;
    overflow: hidden;
    transition: border-color 240ms var(--ease);
  }

  .section-card:first-child { padding-left: 0; }
  .section-card:last-child { padding-right: 0; border-right: none; }

  .section-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms var(--ease);
  }

  .section-card:hover::before { transform: scaleX(1); }

  .section-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    line-height: 1.28;
  }

  .section-card p {
    margin: 0 0 1.2rem;
    color: var(--color-muted);
    font-size: 0.91rem;
    line-height: 1.68;
  }

  .sc-num {
    display: block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    opacity: 0.45;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
    transition: opacity 200ms;
  }

  .section-card:hover .sc-num { opacity: 0.9; }

  .sc-more {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 600;
    transition: gap 200ms var(--ease);
  }

  .section-card:hover .sc-more { gap: 0.5rem; }

  .home-latest { padding: 52px 0 68px; }

  .sec-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.25rem;
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .sec-row h2 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .sec-row a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .sec-row a:hover { gap: 0.55rem; }

  .home-post-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 2rem;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease), background-color 240ms var(--ease);
    color: inherit;
    text-decoration: none;
  }

  .home-post-row:hover {
    background: var(--color-surface-2);
  }

  .home-post-row-inner { min-width: 0; }

  .home-post-row h3 {
    margin: 0.22rem 0 0.35rem;
    font-size: 1.14rem;
    letter-spacing: -0.03em;
    line-height: 1.32;
    transition: color 150ms;
  }

  .home-post-row:hover .home-post-row-inner h3 { color: var(--color-accent); }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-muted);
    font-size: 0.84rem;
    margin-bottom: 0.65rem;
  }

  .post-meta .cat {
    color: var(--color-accent);
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-size: 0.76rem;
  }

  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.62;
    max-width: 660px;
  }

  .home-post-read {
    color: var(--color-accent);
    font-size: 0.74rem;
    white-space: nowrap;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .home-hero {
      min-height: auto;
    }

    .home-hero-inner {
      min-height: 660px;
      align-items: flex-start;
      padding-top: 64px;
    }

    .hero-copy {
      width: min(100%, 600px);
    }

    .signal-art {
      right: -280px;
      bottom: 0;
      top: auto;
      width: 980px;
      transform: none;
      opacity: 0.42;
    }

    :global([data-theme="dark"]) .signal-art-dark {
      opacity: 0.5;
    }

    .alive-grid {
      left: 62%;
      top: 46%;
      width: 420px;
      opacity: 0.18;
    }

    .process-steps {
      max-width: 620px;
    }

    .home-sections { grid-template-columns: repeat(2, 1fr); }
    .home-post-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .home-hero {
      min-height: auto;
    }

    .home-hero::before {
      background:
        linear-gradient(180deg, rgb(0 0 0 / 0.76), rgb(0 0 0 / 0.62) 48%, rgb(0 0 0 / 0.82)),
        radial-gradient(circle at 14% 20%, rgb(121 134 60 / 0.24), transparent 17rem);
      mix-blend-mode: normal;
    }

    :global([data-theme="light"]) .home-hero::before {
      background:
        linear-gradient(180deg, rgb(255 255 255 / 0.9), rgb(255 255 255 / 0.78) 48%, rgb(255 255 255 / 0.92)),
        radial-gradient(circle at 12% 20%, rgb(121 134 60 / 0.15), transparent 17rem);
    }

    .home-hero-inner {
      width: min(100% - 48px, 420px);
      min-height: auto;
      padding-top: 42px;
      padding-bottom: 44px;
    }

    .hero-copy {
      width: 100%;
      padding-top: 0;
    }

    .wordmark {
      font-size: clamp(2rem, 11vw, 2.65rem);
      margin-bottom: 1.3rem;
    }

    .wordmark :global(.brand-word) {
      gap: clamp(0.48rem, 2.7vw, 0.72rem);
    }

    .hero-rule {
      width: 30px;
      height: 3px;
      margin-bottom: 1.35rem;
    }

    .hero-copy h1 {
      max-width: 10.8em;
      font-size: clamp(2.05rem, 9vw, 2.55rem);
      line-height: 1.22;
    }

    .process-steps {
      grid-template-columns: 1fr;
      gap: 0;
      margin-top: 2.4rem;
      padding: 0.25rem 1rem;
      border: 1px solid color-mix(in srgb, var(--color-accent) 22%, transparent);
      border-radius: var(--radius-sm);
      background: color-mix(in srgb, var(--color-surface) 86%, transparent);
      backdrop-filter: blur(10px);
    }

    .process-step,
    .process-step:first-child {
      display: grid;
      grid-template-columns: 38px 1fr;
      column-gap: 1rem;
      align-items: start;
      padding: 1.05rem 0;
      border-left: 0;
      border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    }

    .step-icon {
      width: 34px;
      height: 30px;
      margin: 0.1rem 0 0;
      grid-row: span 2;
    }

    .process-step h2 {
      margin-bottom: 0.28rem;
      font-size: 0.68rem;
      letter-spacing: 0.18em;
      font-weight: 700;
    }

    .process-step p {
      max-width: 18rem;
      font-size: 0.94rem;
      line-height: 1.5;
      color: color-mix(in srgb, var(--color-text) 72%, var(--color-muted));
    }

    .alive-grid {
      display: none;
    }

    .signal-art {
      right: -280px;
      bottom: 3%;
      width: 780px;
      opacity: 0.1;
    }

    :global([data-theme="dark"]) .signal-art-dark {
      opacity: 0.13;
    }

    .home-sections { grid-template-columns: 1fr; }
  }
</style>
