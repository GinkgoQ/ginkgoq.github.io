---
import BaseLayout from "../layouts/BaseLayout.astro";
import SignalGridDots from "../components/SignalGridDots.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "../config/site.config";

const blogPosts = (await getCollection("blog", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "blog",
}));

const researchPosts = (await getCollection("research", ({ data }) => !data.draft)).map((post) => ({
  ...post,
  collection: "research",
}));

const allPosts = [...blogPosts, ...researchPosts];
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const latestPosts = allPosts.slice(0, 3);

const getHref = (post) =>
  post.collection === "blog"
    ? `/blog/${post.id.replace(/\.mdx?$/, "")}/`
    : `/research-notes/${post.id.replace(/\.mdx?$/, "")}/`;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "long",
    day: "numeric",
    year: "numeric",
  }).format(date);

const getReadTime = (post) => {
  const rawBody =
    typeof post.body === "string"
      ? post.body
      : typeof post.body?.raw === "string"
      ? post.body.raw
      : "";
  const words = rawBody.trim().split(/\s+/).filter(Boolean).length;
  return `${Math.max(1, Math.round(words / 220))} min`;
};
---

<BaseLayout title={siteConfig.pages.home.title} description={siteConfig.pages.home.description}>
  <section class="hero container" aria-labelledby="hero-heading">
    <div class="hero-copy">
      <span class="eyebrow">{siteConfig.pages.home.hero.eyebrow}</span>
      <h1 id="hero-heading">{siteConfig.pages.home.hero.title}</h1>
      <p class="lead">{siteConfig.pages.home.hero.lead}</p>
      <a class="hero-link" href={siteConfig.pages.home.hero.ctaRoute}>{siteConfig.pages.home.hero.ctaText}</a>
    </div>

    <div class="hero-graphic">
      <SignalGridDots />
    </div>
  </section>

  <section class="home-sections container" aria-label="GinkgoQ sections">
    {siteConfig.pages.home.sections.map((section) => (
      <a class="section-card" href={section.href}>
        <span class="sc-num" aria-hidden="true">{section.number}</span>
        <h3>{section.title}</h3>
        <p>{section.description}</p>
        <span class="sc-more">{section.actionText}</span>
      </a>
    ))}
  </section>

  <section class="home-latest container" aria-labelledby="latest-heading">
    <div class="sec-row">
      <h2 id="latest-heading">{siteConfig.pages.home.latestHeading}</h2>
      <a href={siteConfig.routes.blog}>{siteConfig.pages.home.latestViewAllText}</a>
    </div>

    <div id="home-posts" role="list">
      {latestPosts.map((post) => (
        <a class="home-post-row" href={getHref(post)} role="listitem">
          <div class="home-post-row-inner">
            <div class="post-meta">
              <time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
              <span class="cat">{post.data.category}</span>
            </div>
            <h3>{post.data.title}</h3>
            <p class="desc">{post.data.description}</p>
          </div>
          <span class="home-post-read">{getReadTime(post)} read</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr 0.82fr;
    gap: 3.5rem;
    align-items: center;
    padding: 80px 0 64px;
  }

  .hero-graphic {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .hero-copy > .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    margin-bottom: 1.8rem;
  }

  .hero-copy > .eyebrow::before {
    content: '';
    display: block;
    width: 18px;
    height: 1.5px;
    background: var(--color-accent);
    border-radius: 999px;
    flex-shrink: 0;
  }

  .hero h1 {
    font-size: clamp(2.75rem, 4.6vw, 5.2rem);
    line-height: 1.01;
    letter-spacing: -0.06em;
    max-width: 540px;
    hyphens: none;
    overflow-wrap: normal;
    word-break: keep-all;
    margin: 0;
  }

  .lead {
    max-width: 460px;
    margin: 1.4rem 0 1.8rem;
    font-size: 1rem;
    color: var(--color-muted);
    line-height: 1.72;
  }

  .hero-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .home-sections {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .section-card {
    display: block;
    color: inherit;
    text-decoration: none;
    padding: 2.2rem 1.8rem;
    border-right: 1px solid var(--color-line);
    position: relative;
    overflow: hidden;
    transition: border-color 240ms var(--ease);
  }

  .section-card:first-child { padding-left: 0; }
  .section-card:last-child { padding-right: 0; border-right: none; }

  .section-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms var(--ease);
  }

  .section-card:hover::before { transform: scaleX(1); }

  .section-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    line-height: 1.28;
  }

  .section-card p {
    margin: 0 0 1.2rem;
    color: var(--color-muted);
    font-size: 0.91rem;
    line-height: 1.68;
  }

  .sc-num {
    display: block;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    color: var(--color-accent);
    opacity: 0.45;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
    transition: opacity 200ms;
  }

  .section-card:hover .sc-num { opacity: 0.9; }

  .sc-more {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 600;
    transition: gap 200ms var(--ease);
  }

  .section-card:hover .sc-more { gap: 0.5rem; }

  .home-latest { padding: 52px 0 68px; }

  .sec-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.25rem;
    margin-bottom: 0;
    border-bottom: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .sec-row h2 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-subtle);
  }

  .sec-row a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 0.82rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .sec-row a:hover { gap: 0.55rem; }

  .home-post-row {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 2rem;
    padding: 1.35rem 0;
    border-bottom: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease), background-color 240ms var(--ease);
    color: inherit;
    text-decoration: none;
  }

  .home-post-row:hover {
    background: var(--color-surface-2);
  }

  .home-post-row-inner { min-width: 0; }

  .home-post-row h3 {
    margin: 0.22rem 0 0.35rem;
    font-size: 1.14rem;
    letter-spacing: -0.03em;
    line-height: 1.32;
    transition: color 150ms;
  }

  .home-post-row:hover .home-post-row-inner h3 { color: var(--color-accent); }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-muted);
    font-size: 0.84rem;
    margin-bottom: 0.65rem;
  }

  .post-meta .cat {
    color: var(--color-accent);
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    font-size: 0.76rem;
  }

  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.88rem;
    line-height: 1.62;
    max-width: 660px;
  }

  .home-post-read {
    color: var(--color-accent);
    font-size: 0.74rem;
    white-space: nowrap;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
    text-decoration: none;
  }

  @media (max-width: 980px) {
    .hero { grid-template-columns: 1fr; padding-top: 64px; }
    .home-sections { grid-template-columns: repeat(2, 1fr); }
    .home-post-row { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .home-sections { grid-template-columns: 1fr; }
    .hero h1 { font-size: 3.4rem; }
  }
</style>
