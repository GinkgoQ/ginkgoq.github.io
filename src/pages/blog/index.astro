---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site.config";

const posts = await getCollection("blog", ({ data }) => !data.draft);

posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const featuredPost = posts.find((post) => post.data.featured) ?? posts[0];
const archivePosts = posts;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en", {
    month: "short",
    day: "numeric",
    year: "numeric",
  }).format(date);

const getSlug = (id: string) => id.replace(/\.mdx?$/, "");

const allCategories = Array.from(
  new Set(posts.map((post) => post.data.category).filter(Boolean))
);

const allTags = Array.from(
  new Set(posts.flatMap((post) => post.data.tags ?? []))
);
---

<BaseLayout
  title={siteConfig.pages.blog.title}
  description={siteConfig.pages.blog.description}
>
  <section class="blog-hero container">
    <div>
      <p class="eyebrow">BLOG</p>
      <h1>Technical writing for real-world AI systems.</h1>
      <p class="lead">
        Notes, build logs, product thinking, and engineering analysis from GinkgoQ.
      </p>
    </div>

    <div class="hero-panel" aria-label="GinkgoQ blog focus areas">
      <p>Focus areas</p>
      <ul>
        <li>AI Systems &amp; Agents</li>
        <li>Domain Intelligence</li>
        <li>RAG &amp; Pipelines</li>
        <li>Datasets &amp; Models</li>
        <li>Production Infrastructure</li>
      </ul>
    </div>
  </section>

  {
    posts.length > 0 ? (
      <>
        <section class="featured container" aria-labelledby="featured-title">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Latest</p>
              <h2 id="featured-title">Featured post</h2>
            </div>
          </div>

          <a class="featured-card" href={`/blog/${getSlug(featuredPost.id)}/`}>
            <div class="featured-copy">
              <p class="post-meta">
                <time datetime={featuredPost.data.date.toISOString()}>
                  {formatDate(featuredPost.data.date)}
                </time>
                <span>{featuredPost.data.category}</span>
              </p>

              <h3>{featuredPost.data.title}</h3>
              <p>{featuredPost.data.description}</p>

              <div class="post-footer">
                <span>Read article →</span>
                {featuredPost.data.tags?.length > 0 && (
                  <ul aria-label="Tags">
                    {featuredPost.data.tags.slice(0, 3).map((tag) => (
                      <li>{tag}</li>
                    ))}
                  </ul>
                )}
              </div>
            </div>

            <div class="featured-visual" aria-hidden="true">
              {featuredPost.data.image ? (
                <img src={featuredPost.data.image} alt="" />
              ) : (
                <div class="abstract-visual">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
              )}
            </div>
          </a>
        </section>

        <section class="blog-grid-section container" aria-labelledby="all-posts-title">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Archive</p>
              <h2 id="all-posts-title">All posts</h2>
            </div>

            <p class="count">{posts.length} posts</p>
          </div>

          <div class="content-grid">
            <div class="posts-list">
              {archivePosts.length > 0 ? (
                archivePosts.map((post) => (
                  <article class="post-row" data-category={post.data.category} data-tags={(post.data.tags ?? []).join(",")}>
                    <a href={`/blog/${getSlug(post.id)}/`}>
                      <div class="post-content">
                        <p class="post-meta">
                          <time datetime={post.data.date.toISOString()}>
                            {formatDate(post.data.date)}
                          </time>
                          <span>{post.data.category}</span>
                        </p>

                        <h3>{post.data.title}</h3>
                        <p>{post.data.description}</p>

                        {post.data.tags?.length > 0 && (
                          <ul class="inline-tags" aria-label="Tags">
                            {post.data.tags.slice(0, 3).map((tag) => (
                              <li>{tag}</li>
                            ))}
                          </ul>
                        )}
                      </div>

                      <div class="post-thumb" aria-hidden="true">
                        {
                          (post.data.image && (
                            <img src={post.data.image} alt="" />
                          )) || (
                            <img src={siteConfig.categories[post.data.category] ?? '/images/og-default.png'} alt="" />
                          )
                        }
                      </div>
                    </a>
                  </article>
                ))
              ) : (
                <p class="empty-small">
                  More posts will appear here after the next publication.
                </p>
              )}
            </div>

            <aside class="blog-sidebar" aria-label="Blog filters and sections">
              {allCategories.length > 0 && (
                <section class="sidebar-block">
                  <h2>Categories</h2>
                  <ul>
                    {allCategories.map((category) => (
                      <li>
                        <a href={`/blog/?category=${encodeURIComponent(category)}`}>
                          {category}
                        </a>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              {allTags.length > 0 && (
                <section class="sidebar-block">
                  <h2>Topics</h2>
                  <div class="tag-cloud">
                    {allTags.slice(0, 18).map((tag) => (
                      <a href={`/blog/?tag=${encodeURIComponent(tag)}`}>{tag}</a>
                    ))}
                  </div>
                </section>
              )}

              <section class="sidebar-block">
                <h2>RSS feed</h2>
                <p>Follow new posts and research notes with our RSS feed.</p>
                <a class="sidebar-link" href="/rss.xml">Subscribe to RSS</a>
              </section>

              <section class="sidebar-block note">
                <h2>GinkgoQ writing</h2>
                <p>
                  Practical notes on AI systems, speech infrastructure, domain
                  intelligence, datasets, models, and production workflows.
                </p>
              </section>
            </aside>
          </div>
        </section>
      </>
    ) : (
      <section class="empty-state container">
        <p class="section-kicker">No posts yet</p>
        <h2>The GinkgoQ blog is being prepared.</h2>
        <p>
          The first articles will cover real-world AI systems, Qoqnus Speechline,
          RAG, agents, healthcare and pharma AI, datasets, and model progress.
        </p>
      </section>
    )
  }
</BaseLayout>

<script type="module">
  const params = new URLSearchParams(location.search);
  const selectedCategory = params.get('category')?.trim().toLowerCase();
  const selectedTag = params.get('tag')?.trim().toLowerCase();
  const postRows = Array.from(document.querySelectorAll('.post-row'));
  const countEl = document.querySelector('.count');
  const filterLabel = selectedCategory ? `Category: ${selectedCategory}` : selectedTag ? `Topic: ${selectedTag}` : null;

  function updateBlogFilter() {
    let visibleCount = 0;
    postRows.forEach((post) => {
      const category = post.dataset.category?.toLowerCase() || '';
      const tags = post.dataset.tags?.toLowerCase().split(',') || [];
      const matchesCategory = selectedCategory ? category === selectedCategory : true;
      const matchesTag = selectedTag ? tags.includes(selectedTag) : true;
      const isVisible = matchesCategory && matchesTag;
      post.style.display = isVisible ? '' : 'none';
      if (isVisible) visibleCount += 1;
    });

    if (countEl) {
      countEl.textContent = `${visibleCount} post${visibleCount === 1 ? '' : 's'}`;
    }

    if (filterLabel && visibleCount === 0) {
      const empty = document.createElement('p');
      empty.className = 'empty-small';
      empty.textContent = 'No posts match this filter. Try another topic or category.';
      const postsList = document.querySelector('.posts-list');
      if (postsList) {
        postsList.innerHTML = '';
        postsList.appendChild(empty);
      }
    }
  }

  if (filterLabel) {
    const heading = document.querySelector('.blog-grid-section .section-heading');
    if (heading) {
      const badge = document.createElement('p');
      badge.className = 'archive-filter';
      badge.textContent = `Filtered by ${filterLabel}`;
      heading.appendChild(badge);
    }
    updateBlogFilter();
  }
</script>

<style>
  .blog-hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 360px;
    gap: 4rem;
    align-items: end;
    padding: 86px 0 70px;
  }

  .eyebrow,
  .section-kicker {
    margin: 0 0 1rem;
    color: var(--color-accent);
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .blog-hero h1 {
    max-width: 860px;
    margin: 0;
    font-size: clamp(3rem, 6vw, 6.25rem);
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .lead {
    max-width: 660px;
    margin: 1.6rem 0 0;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 1.7vw, 1.28rem);
    line-height: 1.6;
  }

  .hero-panel {
    padding: 1.35rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background:
      linear-gradient(180deg, var(--color-surface), var(--color-surface-2)),
      radial-gradient(circle at 12% 12%, var(--color-accent-muted), transparent 40%);
    transition: background 240ms var(--ease), border-color 240ms var(--ease);
  }

  .hero-panel p {
    margin: 0 0 0.9rem;
    color: var(--color-muted);
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-panel ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .hero-panel li {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-text);
    font-size: 0.95rem;
    font-weight: 620;
  }

  .hero-panel li::before {
    content: "";
    width: 0.42rem;
    height: 0.42rem;
    border-radius: 999px;
    background: var(--color-accent);
  }

  .featured,
  .blog-grid-section {
    padding: 0 0 68px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    padding-top: 2.1rem;
    border-top: 1px solid var(--color-line);
  }

  .section-heading h2 {
    margin: 0;
    font-size: clamp(1.65rem, 2.2vw, 2.3rem);
    line-height: 1.1;
    letter-spacing: -0.045em;
  }

  .archive-filter {
    margin: 0.5rem 0 0;
    color: var(--color-accent);
    font-size: 0.88rem;
    font-weight: 700;
  }

  .count {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
  }

  .featured-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 420px;
    gap: 2rem;
    align-items: stretch;
    min-height: 300px;
    padding: 1.4rem;
    color: inherit;
    text-decoration: none;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    position: relative;
    transition:
      border-color 180ms ease,
      transform 180ms ease,
      box-shadow 180ms ease;
  }

  .featured-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--color-accent) 34%, transparent);
    box-shadow: 0 22px 70px rgb(0 0 0 / 0.07);
  }

  .featured-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--color-accent-muted), transparent 60%);
    opacity: 0;
    pointer-events: none;
    transition: opacity 300ms var(--ease);
  }

  .featured-card:hover::after {
    opacity: 0.35;
  }

  .featured-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 1.2rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin: 0 0 0.65rem;
    color: var(--color-muted);
    font-size: 0.84rem;
  }

  .post-meta span {
    color: var(--color-accent);
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .featured-copy h3 {
    max-width: 720px;
    margin: 0;
    font-size: clamp(2rem, 3.5vw, 3.6rem);
    line-height: 1.02;
    letter-spacing: -0.06em;
  }

  .featured-copy > p {
    max-width: 620px;
    margin: 1rem 0 1.4rem;
    color: var(--color-muted);
    font-size: 1.05rem;
    line-height: 1.6;
  }

  .post-footer {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
    margin-top: auto;
  }

  .post-footer > span {
    color: var(--color-accent);
    font-weight: 750;
  }

  .post-footer ul,
  .inline-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .post-footer li,
  .inline-tags li {
    padding: 0.22rem 0.55rem;
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 650;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-surface-2);
  }

  .featured-visual {
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    transition: background-color 240ms var(--ease), border-color 240ms var(--ease);
  }

  .featured-visual img {
    width: 100%;
    height: 100%;
    min-height: 260px;
    object-fit: cover;
    display: block;
  }

  .abstract-visual {
    position: relative;
    height: 100%;
    min-height: 260px;
    overflow: hidden;
  }

  .abstract-visual::before {
    content: "";
    position: absolute;
    inset: 18%;
    background-image:
      linear-gradient(var(--ginkgo-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--ginkgo-grid) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(circle at 42% 52%, black 0 35%, transparent 68%);
    opacity: 0.55;
  }

  .abstract-visual span {
    position: absolute;
    width: 72px;
    height: 72px;
    border: 1px solid rgb(160 168 255 / 0.45);
    border-radius: 999px;
  }

  .abstract-visual span:nth-child(1) {
    left: 22%;
    top: 32%;
  }

  .abstract-visual span:nth-child(2) {
    right: 24%;
    top: 26%;
  }

  .abstract-visual span:nth-child(3) {
    left: 48%;
    bottom: 22%;
  }

  .content-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 270px;
    gap: 4.5rem;
    align-items: start;
  }

  .posts-list {
    border-top: 1px solid var(--color-line);
  }

  .post-row {
    border-bottom: 1px solid var(--color-line);
  }

  .post-row > a {
    display: grid;
    position: relative;
    grid-template-columns: minmax(0, 1fr) 230px;
    gap: 2rem;
    align-items: center;
    padding: 1.55rem 0 1.55rem 1.4rem;
    color: inherit;
    text-decoration: none;
    transition: padding-left 180ms var(--ease);
  }

  .post-row > a::before {
    content: "";
    position: absolute;
    left: 0;
    top: 1.55rem;
    width: 2px;
    height: calc(100% - 3.1rem);
    background: var(--color-accent);
    border-radius: 999px;
    opacity: 0;
    transform: scaleY(0);
    transform-origin: top;
    transition: transform 220ms var(--ease), opacity 220ms var(--ease);
  }

  .post-row > a:hover::before {
    opacity: 1;
    transform: scaleY(1);
  }

  .post-row > a:hover h3 {
    color: var(--color-accent);
  }

  .post-content h3 {
    margin: 0 0 0.45rem;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    line-height: 1.18;
    letter-spacing: -0.04em;
    transition: color 180ms ease;
  }

  .post-content > p {
    max-width: 700px;
    margin: 0 0 0.75rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  .post-thumb {
    overflow: hidden;
    aspect-ratio: 16 / 8.5;
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    transition: background-color 240ms var(--ease), border-color 240ms var(--ease);
  }

  .post-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .thumb-placeholder {
    position: relative;
    height: 100%;
    overflow: hidden;
  }

  .thumb-placeholder::before {
    content: "";
    position: absolute;
    inset: 20%;
    background-image:
      linear-gradient(var(--ginkgo-grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--ginkgo-grid) 1px, transparent 1px);
    background-size: 16px 16px;
    mask-image: radial-gradient(circle at 40% 50%, black 0 30%, transparent 65%);
    opacity: 0.5;
  }

  .thumb-placeholder span {
    position: absolute;
    border: 1px solid rgb(150 160 255 / 0.4);
    border-radius: 999px;
  }

  .thumb-placeholder span:nth-child(1) {
    width: 54px;
    height: 54px;
    left: 24%;
    top: 28%;
  }

  .thumb-placeholder span:nth-child(2) {
    width: 36px;
    height: 36px;
    right: 26%;
    bottom: 24%;
  }

  .blog-sidebar {
    position: sticky;
    top: 2rem;
    display: grid;
    gap: 1rem;
  }

  .sidebar-block {
    padding: 1.1rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    transition: background-color 240ms var(--ease), border-color 240ms var(--ease);
  }

  .sidebar-block h2 {
    margin: 0 0 0.85rem;
    font-size: 0.95rem;
    letter-spacing: -0.02em;
  }

  .sidebar-block ul {
    display: grid;
    gap: 0.55rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sidebar-block a {
    color: var(--color-muted);
    font-size: 0.92rem;
    text-decoration: none;
  }

  .sidebar-block a:hover {
    color: var(--color-accent);
  }

  .sidebar-link {
    display: inline-flex;
    margin-top: 0.75rem;
    color: var(--color-accent);
    font-weight: 700;
    text-decoration: none;
  }

  .sidebar-link:hover {
    color: var(--color-accent);
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag-cloud a {
    padding: 0.24rem 0.55rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: var(--color-surface);
    color: var(--color-muted);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .note p {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .empty-state {
    padding: 80px 0 120px;
    border-top: 1px solid var(--color-line);
  }

  .empty-state h2 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(2.2rem, 4vw, 4.2rem);
    line-height: 1.04;
    letter-spacing: -0.06em;
  }

  .empty-state p:last-child,
  .empty-small {
    max-width: 660px;
    color: var(--color-muted);
  }

  @media (max-width: 1040px) {
    .blog-hero {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .featured-card {
      grid-template-columns: 1fr;
    }

    .content-grid {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      position: static;
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .blog-sidebar .note {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 760px) {
    .blog-hero {
      padding: 60px 0 48px;
    }

    .blog-hero h1 {
      font-size: clamp(3rem, 15vw, 4.4rem);
    }

    .featured-card {
      padding: 1rem;
    }

    .featured-copy {
      padding: 0.25rem;
    }

    .post-row > a {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .post-thumb {
      order: -1;
    }

    .blog-sidebar {
      grid-template-columns: 1fr;
    }

    .section-heading {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
