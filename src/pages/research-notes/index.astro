---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../config/site.config";

const posts = await getCollection("research", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getSlug = (id: string) => id.replace(/\.mdx?$/, "");
---

<BaseLayout title={siteConfig.pages.researchNotes.title} description={siteConfig.pages.researchNotes.description}>
  <section class="rn-listing container" aria-labelledby="rn-heading">
    <span class="eyebrow">Research Notes</span>
    <h1 id="rn-heading">Research Notes</h1>
    <p class="rn-desc">Technical notes, paper observations, experiments, and AI system analysis.</p>

    <div class="rn-items" role="list">
      {posts.map((post) => (
        <a class="rn-item" href={`/research-notes/${getSlug(post.id)}/`} role="listitem">
          <span class="eyebrow">{post.data.category}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .rn-listing {
    padding: 72px 0 96px;
  }

  .eyebrow {
    display: block;
    color: var(--color-accent);
    font-size: 0.8rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 4.5rem);
    line-height: 1;
    letter-spacing: -0.06em;
  }

  .rn-desc {
    max-width: 620px;
    margin: 1rem 0 0;
    color: var(--color-muted);
    font-size: 1.15rem;
  }

  .rn-items {
    margin-top: 3rem;
    border-top: 1px solid var(--color-line);
    transition: border-color 240ms var(--ease);
  }

  .rn-item {
    display: block;
    position: relative;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--color-line);
    color: inherit;
    text-decoration: none;
    transition: padding-left 180ms var(--ease), border-color 240ms var(--ease);
  }

  .rn-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    width: 2px;
    height: 0;
    background: var(--color-accent);
    border-radius: 999px;
    transform: translateY(-50%);
    transition: height 220ms var(--ease);
  }

  .rn-item:hover {
    padding-left: 1rem;
  }

  .rn-item:hover::before {
    height: 50%;
  }

  .rn-item h2 {
    margin: 0.4rem 0;
    font-size: 1.4rem;
    line-height: 1.2;
    letter-spacing: -0.04em;
    transition: color 150ms;
  }

  .rn-item:hover h2 {
    color: var(--color-accent);
  }

  .rn-item p {
    max-width: 720px;
    margin: 0;
    color: var(--color-muted);
  }
</style>
