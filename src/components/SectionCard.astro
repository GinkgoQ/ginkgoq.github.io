---
type Props = {
  title: string;
  description: string;
  icon: string;
  href: string;
};

const { title, description, icon, href } = Astro.props;
---

<a class="section-card" href={href}>
  <div class="icon" aria-hidden="true">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
  <span>Learn more →</span>
</a>

<style>
  .section-card {
    display: block;
    color: inherit;
    text-decoration: none;
    min-width: 0;
  }

  .icon {
    color: var(--color-accent);
    font-size: 1.55rem;
    margin-bottom: 1rem;
  }

  h3 {
    margin: 0 0 0.6rem;
    font-size: 1.05rem;
    line-height: 1.25;
  }

  p {
    margin: 0 0 1rem;
    color: var(--color-text);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  span {
    color: var(--color-accent);
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
