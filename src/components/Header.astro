---
import { navLinks as links } from "../site/navigation";
import { siteConfig } from "../config/site.config";
import BrandText from "./BrandText.astro";
---

<header class="site-header" id="site-header" role="banner">
  <a class="brand" href={siteConfig.routes.home} aria-label={`${siteConfig.brand.name} — home`}>
    <span class="brand-mark" aria-hidden="true">
      <img class="brand-logo" src={siteConfig.brand.logoPath} alt={siteConfig.brand.logoAlt} />
    </span>
    <BrandText text={siteConfig.brand.label} />
  </a>

  <div class="header-middle" role="presentation">
    <nav class="site-nav" id="site-nav" aria-label="Main navigation">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>

    <div class="header-search" id="header-search" role="search" aria-label="Search GinkgoQ">
      <div class="search-inner">
        <label for="search-input" class="sr-only">Search posts and notes</label>
        <div class="search-field">
          <input
            type="search"
            id="search-input"
            class="search-input"
            placeholder={siteConfig.search.placeholder}
            autocomplete="off"
            autocorrect="off"
            spellcheck="false"
            role="combobox"
            aria-haspopup="listbox"
            aria-autocomplete="list"
            aria-controls="search-results-list"
            aria-expanded="false"
          />
          <button class="search-close-hint" id="btn-search-close" aria-label="Close search" hidden type="button">Esc</button>
        </div>
      </div>
    </div>
  </div>

  <div class="header-actions">
    <button class="btn-icon btn-theme" id="btn-theme" aria-label="Switch theme" type="button">
      <svg class="icon-sun" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <circle cx="12" cy="12" r="5" />
        <line x1="12" y1="1" x2="12" y2="3" />
        <line x1="12" y1="21" x2="12" y2="23" />
        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
        <line x1="1" y1="12" x2="3" y2="12" />
        <line x1="21" y1="12" x2="23" y2="12" />
        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
      </svg>
      <svg class="icon-moon" viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
      </svg>
    </button>

    <button class="search-pill" id="btn-search-open" aria-label={siteConfig.search.openButtonLabel} aria-expanded="false" aria-controls="search-results-panel" type="button">
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8" />
        <line x1="21" y1="21" x2="16.65" y2="16.65" />
      </svg>
      <span class="search-pill-label">{siteConfig.search.buttonText}</span>
      <span class="search-kbd-hint" aria-hidden="true"><kbd>⌘</kbd><kbd>K</kbd></span>
    </button>

    <a class="btn-icon" href="/rss.xml" aria-label="Subscribe via RSS" title="Subscribe via RSS">
      <svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M4.5 19.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3Z" />
        <path d="M4.5 12.75c5.623 0 10.185 4.562 10.185 10.185" />
        <path d="M4.5 6c8.284 0 15 6.716 15 15" />
      </svg>
    </a>

    <button class="btn-icon btn-hamburger" id="btn-hamburger" aria-label="Open navigation" aria-expanded="false" aria-controls="mobile-nav" type="button">
      <svg id="icon-hamburger" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6" />
        <line x1="3" y1="12" x2="21" y2="12" />
        <line x1="3" y1="18" x2="21" y2="18" />
      </svg>
      <svg id="icon-hamburger-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true" style="display:none;">
        <line x1="18" y1="6" x2="6" y2="18" />
        <line x1="6" y1="6" x2="18" y2="18" />
      </svg>
    </button>
  </div>
</header>

<div class="mobile-nav" id="mobile-nav" role="dialog" aria-modal="true" aria-hidden="true" aria-label="Mobile navigation">
  <div class="mobile-nav-inner">
    {links.map((link) => (
      <a href={link.href}>{link.label}</a>
    ))}
  </div>
</div>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    padding: 0 52px;
    height: 68px;
    background: var(--color-surface);
    border-bottom: 1px solid transparent;
    transition: border-color 240ms var(--ease), box-shadow 240ms var(--ease), background-color 240ms var(--ease);
  }

  .site-header.scrolled {
    border-bottom-color: var(--color-line);
    box-shadow: 0 2px 14px rgb(0 0 0 / 0.06);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-decoration: none;
    color: var(--color-text);
    margin-right: 2.5rem;
    flex-shrink: 0;
  }

  .brand-mark {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
    background: var(--color-theme-green);
    -webkit-mask: url("/favicon.svg") center / contain no-repeat;
    mask: url("/favicon.svg") center / contain no-repeat;
  }

  .brand-mark img {
    display: none;
  }

  .header-middle {
    position: relative;
    height: 100%;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .site-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
    font-size: 0.82rem;
    font-weight: 580;
    transition: opacity 180ms var(--ease), transform 180ms var(--ease);
  }

  .site-nav a {
    position: relative;
    text-decoration: none;
    color: var(--color-muted);
    padding: 0.25rem 0 3px;
    border-bottom: none;
    transition: color 140ms;
  }

  .site-nav a:hover {
    color: var(--color-text);
  }

  .site-nav a.active {
    color: var(--color-text);
  }

  .site-nav a::after {
    content: "";
    position: absolute;
    right: 0;
    bottom: -1px;
    left: 0;
    height: 1.5px;
    background: var(--color-accent);
    border-radius: 999px;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 220ms var(--ease);
  }

  .site-nav a:hover::after,
  .site-nav a.active::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .header-search {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    opacity: 0;
    pointer-events: none;
    transform: translateY(5px);
    transition: opacity 180ms var(--ease), transform 180ms var(--ease);
  }

  .site-header.search-open .site-nav {
    opacity: 0;
    pointer-events: none;
    transform: translateY(-5px);
  }

  .site-header.search-open .header-search {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .search-inner {
    display: flex;
    align-items: center;
    width: 100%;
    gap: 0.75rem;
  }

  .search-field {
    position: relative;
    width: 100%;
  }

  .search-input {
    width: 100%;
    min-width: 0;
    height: 48px;
    padding: 0 5.5rem 0 1rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-surface-2);
    border: 1px solid var(--color-line);
    border-radius: calc(var(--radius-lg) + 2px);
    outline: none;
    transition: border-color 140ms, box-shadow 140ms, background-color 240ms var(--ease);
    box-sizing: border-box;
  }

  .search-input::placeholder {
    color: var(--color-subtle);
    font-size: 1rem;
  }

  .search-input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-accent-soft);
  }

  .search-kbd,
  .search-kbd-hint {
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--color-subtle);
    background: var(--color-surface-3);
    border: 1px solid var(--color-line);
    border-radius: 6px;
    padding: 0.17rem 0.44rem;
    white-space: nowrap;
    pointer-events: none;
    flex-shrink: 0;
  }
  .search-close-hint {
    position: absolute;
    top: 50%;
    right: 0.5rem;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 64px;
    height: 36px;
    padding: 0 0.75rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    color: var(--color-subtle);
    background: var(--color-surface-3);
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 140ms, border-color 140ms, color 140ms, transform 140ms;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.06);
  }

  .search-close-hint:hover {
    background: var(--color-surface);
    border-color: var(--color-accent-soft);
    color: var(--color-text);
    transform: translateY(-50%) scale(1.02);
  }
  :global(.search-results-panel) {
    background: var(--color-surface);
    border: 1px solid var(--color-line);
    border-top: none;
    border-bottom-left-radius: var(--radius-lg);
    border-bottom-right-radius: var(--radius-lg);
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transform: translateY(-6px);
    transition: max-height 280ms var(--ease), opacity 200ms var(--ease), transform 200ms var(--ease), background-color 240ms var(--ease);
  }

  :global(.search-results-panel.open) {
    max-height: 540px;
    opacity: 1;
    transform: translateY(0);
  }

  :global(.search-results-inner) {
    width: min(var(--container), calc(100% - 104px));
    margin: 0 auto;
    padding: 0.9rem 1rem 1.2rem;
  }

  :global(.search-results-list) {
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
    display: grid;
    gap: 4px;
  }

  :global(.search-results-list > li) {
    list-style: none !important;
    margin: 0;
    padding: 0;
  }

  :global(.search-results-list > li::marker) {
    display: none;
  }

  :global(.search-no-results) {
    padding: 1rem 1rem 1.1rem;
    font-size: 0.95rem;
    color: var(--color-muted);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: 1.5rem;
  }

  .btn-icon {
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    color: var(--color-muted);
    border-radius: var(--radius-sm);
    transition: color 140ms, background-color 140ms;
  }

  .btn-icon:hover {
    background: var(--color-soft);
    color: var(--color-text);
  }

  .btn-theme {
    position: relative;
  }

  .icon-sun,
  .icon-moon {
    transition: opacity 0ms;
  }

  :global([data-theme="dark"]) .icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .icon-moon {
    display: none;
  }

  .search-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.42rem;
    padding: 0.28rem 0.62rem 0.28rem 0.52rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-sm);
    background: var(--color-surface-2);
    color: var(--color-muted);
    font-weight: 600;
    font-size: 0.78rem;
    white-space: nowrap;
    transition: border-color 140ms, color 140ms, background-color 240ms var(--ease), box-shadow 180ms;
  }

  .search-pill:hover {
    border-color: var(--color-accent-soft);
    color: var(--color-text);
    box-shadow: 0 0 0 3px var(--color-accent-muted);
  }

  .search-pill svg {
    flex-shrink: 0;
    opacity: 0.65;
  }

  .search-pill-label {
    color: var(--color-subtle);
  }

  .search-kbd-hint {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    margin-left: 0.1rem;
    padding: 0;
    background: transparent;
    border: 0;
    font-size: 0.68rem;
    user-select: none;
  }

  .search-kbd-hint kbd {
    padding: 0.1rem 0.32rem;
    background: var(--color-surface-3);
    border: 1px solid var(--color-line);
    border-bottom-width: 2px;
    border-radius: 4px;
    font-family: inherit;
    font-size: inherit;
    line-height: 1.4;
  }

  .btn-hamburger {
    display: none;
  }

  .mobile-nav {
    display: none;
  }

  @media (max-width: 980px) {
    .site-header {
      grid-template-columns: auto 1fr auto;
      padding: 0 28px;
      height: auto;
      gap: 0.75rem;
    }

    .header-middle {
      min-width: 0;
    }

    .site-nav {
      display: none;
    }

    .header-search {
      position: static;
      opacity: 1;
      pointer-events: auto;
      transform: none;
      margin-top: 0.75rem;
    }

    .header-actions {
      gap: 0.5rem;
      margin-left: 0;
    }

    .btn-hamburger {
      display: grid;
    }

    .mobile-nav {
      display: block;
      background: var(--color-surface);
      overflow: hidden;
      max-height: 0;
      border-bottom: 1px solid transparent;
      transition: max-height 280ms var(--ease), border-color 240ms var(--ease), background-color 240ms var(--ease);
    }

    .mobile-nav.open {
      max-height: 320px;
      border-bottom-color: var(--color-line);
    }

    .mobile-nav-inner {
      display: flex;
      flex-direction: column;
      padding: 0.5rem 28px 1.25rem;
    }

    .mobile-nav a {
      text-decoration: none;
      color: var(--color-muted);
      padding: 0.85rem 0;
      border-bottom: 1px solid var(--color-line);
      font-size: 1rem;
      font-weight: 600;
      transition: color 140ms, border-color 240ms var(--ease);
    }

    .mobile-nav a:last-child {
      border-bottom: none;
    }

    .mobile-nav a:hover,
    .mobile-nav a.active-mobile {
      color: var(--color-accent);
    }
  }

  @media (max-width: 640px) {
    .site-header {
      grid-template-columns: 1fr auto;
      padding: 0 20px;
    }

    .brand {
      margin-right: 0;
    }

    .header-middle {
      display: none;
    }

    .search-pill {
      display: none;
    }
  }
</style>
