---
type Point = {
  x: number;
  y: number;
};

type SignalNode = {
  x: number;
  y: number;
  type: "solid" | "hollow-circle" | "hollow-square";
};

const width = 420;
const height = 340;

const strokeColor = "#4c4a78";
const veinColor = "#737dde";
const stemColor = "#1f276f";
const gridColor = "#e4e7f6";
const nodeColor = "#33306f";

const stemBase: Point = { x: 132, y: 320 };
const stemTop: Point = { x: 205, y: 248 };

const fmt = (value: number) => Number(value.toFixed(2));

const point = (x: number, y: number): Point => ({ x, y });

const cubicPoint = (p0: Point, p1: Point, p2: Point, p3: Point, t: number): Point => {
  const u = 1 - t;

  return {
    x:
      u * u * u * p0.x +
      3 * u * u * t * p1.x +
      3 * u * t * t * p2.x +
      t * t * t * p3.x,
    y:
      u * u * u * p0.y +
      3 * u * u * t * p1.y +
      3 * u * t * t * p2.y +
      t * t * t * p3.y,
  };
};

const sampleCubic = (
  p0: Point,
  p1: Point,
  p2: Point,
  p3: Point,
  steps: number,
  skipFirst = false
): Point[] => {
  const start = skipFirst ? 1 : 0;

  return Array.from({ length: steps - start + 1 }, (_, index) => {
    const t = (index + start) / steps;
    return cubicPoint(p0, p1, p2, p3, t);
  });
};

const rawEdgePoints: Point[] = [
  ...sampleCubic(
    point(86, 168),
    point(80, 130),
    point(120, 92),
    point(166, 84),
    16
  ),
  ...sampleCubic(
    point(166, 84),
    point(188, 55),
    point(216, 76),
    point(230, 164),
    18,
    true
  ),
  ...sampleCubic(
    point(230, 164),
    point(238, 128),
    point(253, 98),
    point(278, 100),
    12,
    true
  ),
  ...sampleCubic(
    point(278, 100),
    point(315, 82),
    point(354, 126),
    point(360, 169),
    18,
    true
  ),
  ...sampleCubic(
    point(360, 169),
    point(365, 195),
    point(348, 218),
    point(328, 224),
    12,
    true
  ),
];

const edgePoints = rawEdgePoints.map((p, index) => {
  const t = index / (rawEdgePoints.length - 1);
  const outerEdge = t > 0.04 && t < 0.9;
  const amplitude = outerEdge ? 3.6 : 1.2;
  const wave = Math.sin(t * Math.PI * 23 + 0.42) * amplitude;

  return {
    x: p.x,
    y: p.y + wave,
  };
});

const catmullRomPath = (points: Point[]): string => {
  let d = `M ${fmt(points[0].x)} ${fmt(points[0].y)}`;

  for (let i = 0; i < points.length - 1; i += 1) {
    const p0 = points[Math.max(0, i - 1)];
    const p1 = points[i];
    const p2 = points[i + 1];
    const p3 = points[Math.min(points.length - 1, i + 2)];

    const cp1 = {
      x: p1.x + (p2.x - p0.x) / 6,
      y: p1.y + (p2.y - p0.y) / 6,
    };

    const cp2 = {
      x: p2.x - (p3.x - p1.x) / 6,
      y: p2.y - (p3.y - p1.y) / 6,
    };

    d += ` C ${fmt(cp1.x)} ${fmt(cp1.y)} ${fmt(cp2.x)} ${fmt(cp2.y)} ${fmt(p2.x)} ${fmt(p2.y)}`;
  }

  return d;
};

const outlinePath = catmullRomPath(edgePoints);

const veinCount = 66;

const veinPaths = Array.from({ length: veinCount }, (_, index) => {
  const t = index / (veinCount - 1);
  const edgeIndex = Math.round(t * (edgePoints.length - 1));
  const end = edgePoints[edgeIndex];
  const side = end.x < 230 ? -1 : 1;
  const edgeDistance = Math.abs(t - 0.5) * 2;
  const bend = 6 + edgeDistance * 10;

  const cp1 = {
    x: stemTop.x + (end.x - stemTop.x) * 0.24 + side * bend * 0.18,
    y: stemTop.y + (end.y - stemTop.y) * 0.27 - 5,
  };

  const cp2 = {
    x: stemTop.x + (end.x - stemTop.x) * 0.69 + side * bend,
    y: stemTop.y + (end.y - stemTop.y) * 0.72 - 2,
  };

  return `M ${fmt(stemTop.x)} ${fmt(stemTop.y)} C ${fmt(cp1.x)} ${fmt(cp1.y)} ${fmt(cp2.x)} ${fmt(cp2.y)} ${fmt(end.x)} ${fmt(end.y)}`;
});

const gridX = Array.from({ length: 9 }, (_, index) => 60 + index * 40);
const gridY = Array.from({ length: 8 }, (_, index) => 40 + index * 40);

const nodes: SignalNode[] = [
  { x: 92, y: 84, type: "solid" },
  { x: 172, y: 42, type: "solid" },
  { x: 222, y: 42, type: "hollow-circle" },
  { x: 282, y: 42, type: "solid" },
  { x: 350, y: 82, type: "hollow-square" },
  { x: 386, y: 122, type: "solid" },
  { x: 382, y: 202, type: "hollow-circle" },
  { x: 344, y: 242, type: "solid" },
  { x: 302, y: 282, type: "hollow-square" },
  { x: 242, y: 286, type: "solid" },
  { x: 202, y: 284, type: "hollow-circle" },
  { x: 164, y: 242, type: "solid" },
  { x: 122, y: 244, type: "solid" },
  { x: 82, y: 202, type: "hollow-circle" },
  { x: 82, y: 162, type: "solid" },
  { x: 122, y: 122, type: "solid" },
  { x: 162, y: 122, type: "solid" },
  { x: 202, y: 162, type: "hollow-square" },
  { x: 242, y: 162, type: "solid" },
  { x: 302, y: 202, type: "hollow-circle" },
  { x: 322, y: 122, type: "solid" },
];
---

<div class="ginkgo-signal-graphic" aria-hidden="true">
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox={`0 0 ${width} ${height}`}
    role="img"
  >
    <defs>
      <radialGradient id="ginkgoGridFade" cx="52%" cy="47%" r="58%">
        <stop offset="0%" stop-color="white" stop-opacity="1" />
        <stop offset="74%" stop-color="white" stop-opacity="0.84" />
        <stop offset="100%" stop-color="white" stop-opacity="0" />
      </radialGradient>

      <radialGradient id="ginkgoLeafGlow" cx="52%" cy="49%" r="54%">
        <stop offset="0%" stop-color="#6f7cea" stop-opacity="0.095" />
        <stop offset="65%" stop-color="#6f7cea" stop-opacity="0.032" />
        <stop offset="100%" stop-color="#6f7cea" stop-opacity="0" />
      </radialGradient>

      <mask id="ginkgoGridMask">
        <rect x="36" y="18" width="360" height="304" fill="url(#ginkgoGridFade)" />
      </mask>
    </defs>

    <g class="grid" mask="url(#ginkgoGridMask)">
      {gridX.map((x) => (
        <line x1={x} y1="20" x2={x} y2="320" />
      ))}
      {gridY.map((y) => (
        <line x1="40" y1={y} x2="390" y2={y} />
      ))}
    </g>

    <g class="nodes">
      {nodes.map((node) => (
        node.type === "solid" ? (
          <circle cx={node.x} cy={node.y} r="2.15" />
        ) : node.type === "hollow-circle" ? (
          <circle class="hollow" cx={node.x} cy={node.y} r="2.55" />
        ) : (
          <rect
            class="hollow"
            x={node.x - 2.55}
            y={node.y - 2.55}
            width="5.1"
            height="5.1"
            rx="0.7"
          />
        )
      ))}
    </g>

    <ellipse class="leaf-glow" cx="225" cy="170" rx="156" ry="120" />

    <g class="leaf">
      <path class="outline" d={outlinePath} />

      {veinPaths.map((path) => (
        <path class="vein" d={path} />
      ))}

      <path
        class="stem"
        d={`M ${stemBase.x} ${stemBase.y} C 146 296 178 264 ${stemTop.x} ${stemTop.y}`}
      />

      <path
        class="fold"
        d={`M ${stemTop.x} ${stemTop.y} C 211 219 219 188 230 164`}
      />

      <path
        class="lower-vein"
        d={`M ${stemTop.x} ${stemTop.y} C 244 222 286 214 328 224`}
      />
    </g>
  </svg>
</div>

<style>
  .ginkgo-signal-graphic {
    width: min(480px, 100%);
    margin-left: auto;
    color: var(--color-accent, #3047d5);
  }

  svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    shape-rendering: geometricPrecision;
  }

  .grid line {
    stroke: #e4e7f6;
    stroke-width: 0.75;
    vector-effect: non-scaling-stroke;
  }

  .nodes {
    fill: #33306f;
    stroke: #33306f;
    opacity: 0.58;
  }

  .nodes .hollow {
    fill: white;
    fill-opacity: 0.18;
    stroke-width: 0.9;
    vector-effect: non-scaling-stroke;
  }

  .leaf-glow {
    fill: url("#ginkgoLeafGlow");
  }

  .leaf {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .outline {
    stroke: #4c4a78;
    stroke-width: 1.35;
    opacity: 0.84;
    vector-effect: non-scaling-stroke;
  }

  .vein {
    stroke: #737dde;
    stroke-width: 0.58;
    opacity: 0.43;
    vector-effect: non-scaling-stroke;
  }

  .stem {
    stroke: #1f276f;
    stroke-width: 2.1;
    opacity: 0.96;
    vector-effect: non-scaling-stroke;
  }

  .fold {
    stroke: #4c4a78;
    stroke-width: 1.25;
    opacity: 0.82;
    vector-effect: non-scaling-stroke;
  }

  .lower-vein {
    stroke: #737dde;
    stroke-width: 0.95;
    opacity: 0.5;
    vector-effect: non-scaling-stroke;
  }

  @media (max-width: 980px) {
    .ginkgo-signal-graphic {
      width: min(420px, 100%);
      margin-left: 0;
    }
  }
</style>